# Django Settings
DJANGO_SECRET_KEY=django-insecure-generate-a-50-character-string-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Set USE_SQLITE=True to use local SQLite for development
USE_SQLITE=True

# PostgreSQL Configuration (Needed if USE_SQLITE=False)
DB_NAME=promptatlas
DB_USER=pa_user
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# JWT Settings (Optional: override defaults)
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
# JWT_REFRESH_TOKEN_LIFETIME_DAYS=30
